# Root .env — read by docker-compose for service configuration
# Copy to .env and fill in values

# Required by the MySQL container (root password for the DB service)
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# Must match DB_PASS in backend/.env — Docker Compose uses this to set the
# MySQL user password when creating the tracker user inside the DB container
DB_PASS=change_me_db_password

# Override the published port for the frontend container (default: 3000)
# Set to 3001 if you want Docker on 3001 and local CRA dev on 3002
APP_PORT=3001
