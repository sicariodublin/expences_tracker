# Database
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_PORT=3306
DB_NAME=expense_tracker

# Email (set EMAIL_DEV_MODE=ethereal to use a free test inbox instead of real SMTP)
SMTP_VERIFY=false
EMAIL_DEV_MODE=ethereal
REPORT_FROM_EMAIL=no-reply@expense-tracker.local

# Security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing JWT_SECRET invalidates all active sessions (users must log in again)
# WARNING: changing EMAIL_SECRET_KEY will make stored SMTP passwords unreadable — only change
#          if no email settings have been saved yet, or after clearing the email_settings table
JWT_SECRET=replace-with-64-char-hex-string
EMAIL_SECRET_KEY=replace-with-64-char-hex-string

# Optional: comma-separated extra origins to allow in CORS (e.g. https://yourdomain.com)
# CORS_ORIGIN=
